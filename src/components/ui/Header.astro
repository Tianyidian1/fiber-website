---
import { useTranslations, getLangFromUrl, getLocalizedPath } from '../../i18n/index';

export interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as any);

const productCategories = [
  { key: 'cat.pm', href: '/products/pm-patch-cord', icon: '🔵' },
  { key: 'cat.hd', href: '/products/high-density', icon: '🟦' },
  { key: 'cat.test', href: '/products/test-solutions', icon: '🔬' },
  { key: 'cat.special', href: '/products/specialty', icon: '⚡' },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50 border-b border-gray-200">
  <!-- Top bar -->
  <div class="bg-brand-blue-dark text-white text-xs py-1.5">
    <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
      <span>
        {lang === 'en' ? '📧 info@fiberlink.com  |  📞 +86-400-000-0000' : '📧 info@fiberlink.com  |  📞 400-000-0000'}
      </span>
      <div class="flex items-center gap-4">
        <a href={lang === 'en' ? '/' : '/en'} class="hover:text-blue-200 transition-colors font-medium">
          {lang === 'en' ? '中文' : 'English'}
        </a>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={lang === 'en' ? '/en' : '/'} class="flex items-center gap-3 flex-shrink-0">
        <div class="w-10 h-10 bg-brand-blue rounded flex items-center justify-center">
          <svg viewBox="0 0 24 24" class="w-6 h-6 text-white" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
          </svg>
        </div>
        <div>
          <div class="text-xl font-bold text-brand-blue leading-tight">FiberLink</div>
          <div class="text-xs text-gray-500 leading-tight">{lang === 'en' ? 'Fiber Optic Solutions' : '光纤跳线专家'}</div>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        <!-- Solutions dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-blue hover:bg-brand-blue-light rounded transition-colors">
            {t('nav.solutions')}
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-64 bg-white shadow-xl rounded-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="p-2">
              <a href={getLocalizedPath('/solutions', lang)} class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-brand-blue-light text-gray-700 hover:text-brand-blue transition-colors">
                <span class="text-lg">💡</span>
                <span class="font-medium text-sm">{t('solutions.title')}</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Products dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-blue hover:bg-brand-blue-light rounded transition-colors">
            {t('nav.products')}
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <!-- Mega dropdown -->
          <div class="absolute top-full left-0 mt-1 w-64 bg-white shadow-xl rounded-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="p-2">
              {productCategories.map(cat => (
                <a
                  href={getLocalizedPath(cat.href, lang)}
                  class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-brand-blue-light text-gray-700 hover:text-brand-blue transition-colors"
                >
                  <span class="text-lg">{cat.icon}</span>
                  <span class="font-medium text-sm">{t(cat.key as any)}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href={getLocalizedPath('/about', lang)} class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-blue hover:bg-brand-blue-light rounded transition-colors">
          {t('nav.about')}
        </a>
        <a href={getLocalizedPath('/contact', lang)} class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-blue hover:bg-brand-blue-light rounded transition-colors">
          {t('nav.contact')}
        </a>
      </nav>

      <!-- Right actions -->
      <div class="hidden lg:flex items-center gap-3">
        <!-- Sample Request -->
        <a href={getLocalizedPath('/contact', lang)} class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-green-600 hover:text-green-700 bg-green-50 hover:bg-green-100 rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          {t('nav.sample')}
        </a>

        <!-- Search -->
        <div class="relative">
          <input
            type="text"
            placeholder={t('nav.search')}
            class="w-48 pl-9 pr-4 py-2 text-sm bg-gray-50 border border-gray-200 rounded-full focus:outline-none focus:ring-2 focus:ring-brand-blue focus:bg-white transition-all"
          />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>

        <!-- Inquire button -->
        <button
          onclick="document.dispatchEvent(new CustomEvent('open-inquiry'))"
          class="btn-primary text-sm py-2 px-5"
        >
          {t('hero.inquire')}
        </button>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="max-w-7xl mx-auto px-4 py-3 space-y-1">
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 py-2">{t('nav.solutions')}</div>
      <a href={getLocalizedPath('/solutions', lang)} class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-50 text-gray-700 text-sm">
        <span>💡</span>
        <span>{t('solutions.title')}</span>
      </a>
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 py-2">{t('nav.products')}</div>
      {productCategories.map(cat => (
        <a href={getLocalizedPath(cat.href, lang)} class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-50 text-gray-700 text-sm">
          <span>{cat.icon}</span>
          <span>{t(cat.key as any)}</span>
        </a>
      ))}
      <div class="border-t border-gray-100 pt-2 mt-2">
        <a href={getLocalizedPath('/about', lang)} class="block px-3 py-2.5 text-sm text-gray-700 hover:bg-gray-50 rounded-lg">{t('nav.about')}</a>
        <a href={getLocalizedPath('/contact', lang)} class="block px-3 py-2.5 text-sm text-gray-700 hover:bg-gray-50 rounded-lg">{t('nav.contact')}</a>
      </div>
      <div class="pt-2">
        <a href={getLocalizedPath('/contact', lang)} class="flex items-center justify-center gap-2 w-full text-sm font-medium text-green-600 bg-green-50 hover:bg-green-100 rounded-lg py-2.5 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          {t('nav.sample')}
        </a>
        <button onclick="document.dispatchEvent(new CustomEvent('open-inquiry'))" class="w-full btn-primary text-sm py-2.5 justify-center mt-2">
          {t('hero.inquire')}
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
