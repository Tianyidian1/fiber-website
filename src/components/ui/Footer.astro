---
import { useTranslations, getLocalizedPath } from '../../i18n/index';

export interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang as any);

const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-brand-blue rounded flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-6 h-6 text-white" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
            </svg>
          </div>
          <div>
            <div class="text-xl font-bold">FiberLink</div>
            <div class="text-xs text-gray-400">{lang === 'en' ? 'Fiber Optic Solutions' : '光纤跳线专家'}</div>
          </div>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-4">
          {lang === 'en'
            ? 'Professional fiber optic interconnect solutions. Specializing in PM patch cords, high-density MPO, OTDR test, and specialty cables.'
            : '专业光纤互联解决方案供应商，专注于保偏跳线、高密度MPO、OTDR测试及特种跳线产品。'}
        </p>
        <!-- Social links -->
        <div class="flex gap-3">
          <a href="#" class="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center hover:bg-brand-blue transition-colors text-sm">
            in
          </a>
          <a href="#" class="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center hover:bg-brand-blue transition-colors text-sm">
            📧
          </a>
          <a href="#" class="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center hover:bg-brand-blue transition-colors text-sm">
            💬
          </a>
        </div>
      </div>

      <!-- Products -->
      <div>
        <h3 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">{t('footer.products')}</h3>
        <ul class="space-y-2">
          <li><a href={getLocalizedPath('/products/pm-patch-cord', lang)} class="text-gray-400 hover:text-white text-sm transition-colors">{t('cat.pm')}</a></li>
          <li><a href={getLocalizedPath('/products/high-density', lang)} class="text-gray-400 hover:text-white text-sm transition-colors">{t('cat.hd')}</a></li>
          <li><a href={getLocalizedPath('/products/test-solutions', lang)} class="text-gray-400 hover:text-white text-sm transition-colors">{t('cat.test')}</a></li>
          <li><a href={getLocalizedPath('/products/specialty', lang)} class="text-gray-400 hover:text-white text-sm transition-colors">{t('cat.special')}</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">{t('footer.company')}</h3>
        <ul class="space-y-2">
          <li><a href={getLocalizedPath('/about', lang)} class="text-gray-400 hover:text-white text-sm transition-colors">{t('footer.about')}</a></li>
          <li><a href={getLocalizedPath('/contact', lang)} class="text-gray-400 hover:text-white text-sm transition-colors">{t('footer.contact')}</a></li>
          <li><a href={getLocalizedPath('/contact#faq', lang)} class="text-gray-400 hover:text-white text-sm transition-colors">{t('footer.faq')}</a></li>
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h3 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">{t('contact.title')}</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-2 text-sm text-gray-400">
            <span class="text-brand-blue mt-0.5">📍</span>
            <span>{lang === 'en' ? 'No.1 Fiber Road, Tech Park, Shenzhen, China' : '中国深圳市科技园光纤路1号'}</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-gray-400">
            <span class="text-brand-blue">📞</span>
            <a href="tel:+86-400-000-0000" class="hover:text-white transition-colors">+86-400-000-0000</a>
          </li>
          <li class="flex items-center gap-2 text-sm text-gray-400">
            <span class="text-brand-blue">📧</span>
            <a href="mailto:info@fiberlink.com" class="hover:text-white transition-colors">info@fiberlink.com</a>
          </li>
          <li class="flex items-start gap-2 text-sm text-gray-400">
            <span class="text-brand-blue">🕐</span>
            <span>{t('contact.hours.value')}</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col md:flex-row justify-between items-center gap-2 text-xs text-gray-500">
      <span>© {year} FiberLink Technology. {t('footer.copyright')}.</span>
      <div class="flex gap-4">
        <a href="#" class="hover:text-gray-300 transition-colors">
          {lang === 'en' ? 'Privacy Policy' : '隐私政策'}
        </a>
        <a href="#" class="hover:text-gray-300 transition-colors">
          {lang === 'en' ? 'Terms of Service' : '服务条款'}
        </a>
      </div>
    </div>
  </div>
</footer>
