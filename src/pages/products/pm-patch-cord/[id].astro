---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../../i18n/index';

export function getStaticPaths() {
  const products = [
    {
      id: 'pm-lc-apc-1m',
      slug: 'pm-lc-apc-1m',
      nameZh: 'LC/APC 保偏跳线 1m',
      nameEn: 'LC/APC Panda PM fiber patch cable 1m',
      model: 'FL-PM-LC/APC-1M',
      descZh: '采用熊猫型保偏光纤（PM1550），LC/APC连接器，专为需要精确偏振控制的应用设计。超低插入损耗保证信号完整性，高消光比确保偏振维持性能。广泛应用于相干光通信、光纤传感、量子通信及激光系统。',
      descEn: 'Panda-type PM fiber (PM1550) with LC/APC connectors, designed for applications requiring precise polarization control. Ultra-low insertion loss ensures signal integrity, and high extinction ratio guarantees PM performance. Widely used in coherent optical communication, fiber sensing, quantum communication, and laser systems.',
      specsZh: {
        '光纤类型': 'PM1550 熊猫型 (Panda)',
        '工作波长': '1550 nm',
        '连接器类型': 'LC/APC',
        '插入损耗': '< 0.3 dB（典型值 0.15dB）',
        '回波损耗': '> 60 dB',
        '消光比': '≥ 25 dB',
        '线缆外径': '0.9 mm',
        '护套材料': 'PVC（可选不锈钢铠装）',
        '线缆颜色': '白色（可定制红/蓝/黄）',
        '长度': '1 m（支持0.1m–100m定制）',
        '工作温度': '-40°C 至 +85°C',
        '存储温度': '-55°C 至 +85°C',
        '抗拉强度': '5 N',
        '最小弯曲半径': '30 mm（短期）/ 60mm（长期）',
        '端面研磨': 'APC（8° 斜面抛光）',
        '互换性': 'IEC 61300-2-2 compliant',
      },
      specsEn: {
        'Fiber Type': 'PM1550 Panda',
        'Operating Wavelength': '1550 nm',
        'Connector': 'LC/APC',
        'Insertion Loss': '< 0.3 dB (typical 0.15dB)',
        'Return Loss': '> 60 dB',
        'Extinction Ratio': '≥ 25 dB',
        'Cable OD': '0.9 mm',
        'Jacket Material': 'PVC (stainless steel armored optional)',
        'Cable Color': 'White (Red/Blue/Yellow custom)',
        'Length': '1 m (0.1m–100m custom)',
        'Operating Temperature': '-40°C to +85°C',
        'Storage Temperature': '-55°C to +85°C',
        'Tensile Strength': '5 N',
        'Min Bend Radius': '30 mm (short-term) / 60mm (long-term)',
        'Polish': 'APC (8° angled)',
        'Interchangeability': 'IEC 61300-2-2 compliant',
      },
      applications: ['coherent-comm', 'sensing', 'quantum', 'laser'],
      relatedProducts: ['pm-fc-pc-2m', 'pm-sc-apc-armored', 'pm-lc-fc-hybrid'],
      category: 'pm-patch-cord',
      alibabaLink: 'https://alibaba.com/demo-product',
    },
    {
      id: 'pm-fc-pc-2m',
      slug: 'pm-fc-pc-2m',
      nameZh: 'FC/PC 保偏跳线 2m',
      nameEn: 'FC/PC Panda PM fiber patch cable 2m',
      model: 'FL-PM-FC/PC-2M',
      descZh: '熊猫型PM1550保偏光纤，FC/PC连接器，2.0mm PVC护套，适用于实验室和工程现场。',
      descEn: 'Panda PM1550 fiber with FC/PC connector, 2.0mm PVC jacket, for lab and field applications.',
      specsZh: {
        '光纤类型': 'PM1550 熊猫型',
        '工作波长': '1550 nm',
        '连接器类型': 'FC/PC',
        '插入损耗': '< 0.3 dB',
        '消光比': '≥ 25 dB',
        '线缆外径': '2.0 mm',
        '长度': '2 m',
        '工作温度': '-40°C 至 +85°C',
      },
      specsEn: {
        'Fiber Type': 'PM1550 Panda',
        'Wavelength': '1550 nm',
        'Connector': 'FC/PC',
        'Insertion Loss': '< 0.3 dB',
        'Extinction Ratio': '≥ 25 dB',
        'Cable OD': '2.0 mm',
        'Length': '2 m',
        'Temp Range': '-40°C to +85°C',
      },
      applications: ['laser', 'sensing'],
      relatedProducts: ['pm-lc-apc-1m', 'pm-sc-apc-armored'],
      category: 'pm-patch-cord',
      alibabaLink: '',
    },
    {
      id: 'pm-sc-apc-armored',
      slug: 'pm-sc-apc-armored',
      nameZh: 'SC/APC 保偏铠装跳线 1m',
      nameEn: 'SC/APC PM Armored Patch Cord 1m',
      model: 'FL-PM-SC/APC-ARM-1M',
      descZh: '熊猫型PM1550保偏光纤，SC/APC连接器，3.0mm不锈钢铠装护套，高消光比≥30dB，适用于恶劣环境。',
      descEn: 'Panda PM1550 with SC/APC, 3.0mm stainless steel armored jacket, ER≥30dB, for harsh environments.',
      specsZh: {
        '光纤类型': 'PM1550 熊猫型',
        '连接器类型': 'SC/APC',
        '插入损耗': '< 0.3 dB',
        '消光比': '≥ 30 dB',
        '线缆外径': '3.0 mm 铠装',
        '长度': '1 m',
        '工作温度': '-40°C 至 +85°C',
      },
      specsEn: {
        'Fiber Type': 'PM1550 Panda',
        'Connector': 'SC/APC',
        'Insertion Loss': '< 0.3 dB',
        'Extinction Ratio': '≥ 30 dB',
        'Cable OD': '3.0mm Armored',
        'Length': '1 m',
        'Temp Range': '-40°C to +85°C',
      },
      applications: ['industrial', 'sensing'],
      relatedProducts: ['pm-lc-apc-1m', 'pm-fc-pc-2m'],
      category: 'pm-patch-cord',
      alibabaLink: '',
    },
    {
      id: 'pm-lc-fc-hybrid',
      slug: 'pm-lc-fc-hybrid',
      nameZh: 'LC/APC-FC/APC 保偏混接跳线 2m',
      nameEn: 'LC/APC-FC/APC PM Hybrid Patch Cord 2m',
      model: 'FL-PM-LC-FC-HYB-2M',
      descZh: 'LC/APC 转 FC/APC 混合接头保偏跳线，适用于不同接口设备互联。',
      descEn: 'LC/APC to FC/APC hybrid Panda PM fiber patch cable for interconnecting equipment with different connector interfaces.',
      specsZh: {
        '光纤类型': 'PM1550 熊猫型',
        '连接器A端': 'LC/APC',
        '连接器B端': 'FC/APC',
        '插入损耗': '< 0.5 dB',
        '消光比': '≥ 20 dB',
        '长度': '2 m',
      },
      specsEn: {
        'Fiber Type': 'PM1550 Panda',
        'Connector End A': 'LC/APC',
        'Connector End B': 'FC/APC',
        'Insertion Loss': '< 0.5 dB',
        'Extinction Ratio': '≥ 20 dB',
        'Length': '2 m',
      },
      applications: ['lab', 'system-integration'],
      relatedProducts: ['pm-lc-apc-1m', 'pm-fc-pc-2m'],
      category: 'pm-patch-cord',
      alibabaLink: '',
    },
  ];

  return products.map(product => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const name = lang === 'en' ? product.nameEn : product.nameZh;
const desc = lang === 'en' ? product.descEn : product.descZh;
const specs = lang === 'en' ? product.specsEn : product.specsZh;

const applicationLabels: Record<string, { zh: string; en: string }> = {
  'coherent-comm': { zh: '相干光通信', en: 'Coherent Communication' },
  'sensing': { zh: '光纤传感', en: 'Fiber Sensing' },
  'quantum': { zh: '量子通信', en: 'Quantum Communication' },
  'laser': { zh: '激光系统', en: 'Laser Systems' },
  'industrial': { zh: '工业应用', en: 'Industrial Applications' },
  'lab': { zh: '实验室', en: 'Laboratory' },
  'system-integration': { zh: '系统集成', en: 'System Integration' },
};
---

<Layout
  title={`${name} ${product.model} – FiberLink`}
  description={desc.substring(0, 160)}
  productModel={product.model}
>
  <Breadcrumb
    lang={lang}
    items={[
      { label: lang === 'en' ? 'Products' : '产品', href: '/' },
      { label: lang === 'en' ? 'Panda PM Fiber Patch Cables' : '保偏跳线', href: '/products/pm-patch-cord' },
    ]}
    current={name}
  />

  <div class="max-w-7xl mx-auto px-4 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <!-- Left: Image Gallery -->
      <div>
        <!-- Main image -->
        <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-12 flex justify-center items-center mb-4 aspect-square max-w-sm mx-auto lg:max-w-none">
          <span class="text-9xl select-none">🔵</span>
        </div>
        <!-- Thumbnails -->
        <div class="flex gap-3 justify-center">
          {[1, 2, 3].map(i => (
            <button class={`w-16 h-16 rounded-lg bg-gradient-to-br from-blue-50 to-blue-100 flex items-center justify-center border-2 ${i === 1 ? 'border-brand-blue' : 'border-transparent hover:border-gray-300'} transition-colors`}>
              <span class="text-2xl">🔵</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Right: Product Info -->
      <div>
        <!-- Model badge -->
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs font-mono bg-gray-100 text-gray-600 px-2 py-1 rounded">{product.model}</span>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded font-medium">
            {lang === 'en' ? '✓ In Stock' : '✓ 现货'}
          </span>
        </div>

        <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-4">{name}</h1>

        <p class="text-gray-600 leading-relaxed mb-6 text-sm">{desc}</p>

        <!-- Application tags -->
        <div class="flex flex-wrap gap-2 mb-6">
          {product.applications.map(app => (
            <span class="px-3 py-1 bg-brand-blue-light text-brand-blue text-xs font-medium rounded-full">
              {lang === 'en' ? applicationLabels[app]?.en : applicationLabels[app]?.zh}
            </span>
          ))}
        </div>

        <!-- Order guide -->
        <div class="bg-gray-50 rounded-xl p-5 mb-6">
          <h3 class="font-semibold text-gray-800 mb-3 text-sm">{t('product.order')}</h3>
          <div class="space-y-3">
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">{t('product.connector')}</label>
              <div class="flex flex-wrap gap-2">
                {['LC/APC', 'LC/UPC', 'FC/APC', 'FC/PC', 'SC/APC', 'SC/UPC', 'ST/PC', 'MU/APC'].map(c => (
                  <button class="px-3 py-1.5 text-xs border border-gray-200 rounded-lg hover:border-brand-blue hover:text-brand-blue transition-colors">
                    {c}
                  </button>
                ))}
              </div>
            </div>
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">{t('product.diameter')}</label>
              <div class="flex gap-2">
                {['0.9mm', '2.0mm', '3.0mm', lang === 'en' ? 'Armored' : '铠装'].map(d => (
                  <button class="px-3 py-1.5 text-xs border border-gray-200 rounded-lg hover:border-brand-blue hover:text-brand-blue transition-colors">
                    {d}
                  </button>
                ))}
              </div>
            </div>
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">{t('product.length')}</label>
              <div class="flex flex-wrap gap-2">
                {['0.5m', '1m', '2m', '3m', '5m', lang === 'en' ? 'Custom' : '定制'].map(l => (
                  <button class="px-3 py-1.5 text-xs border border-gray-200 rounded-lg hover:border-brand-blue hover:text-brand-blue transition-colors">
                    {l}
                  </button>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mb-6">
          <button
            onclick={`document.dispatchEvent(new CustomEvent('open-inquiry', {detail:{product:'${product.model}'}}))`}
            class="flex-1 btn-primary justify-center py-3.5 text-base"
          >
            📧 {t('product.inquire')}
          </button>
          {product.alibabaLink ? (
            <a
              href={product.alibabaLink}
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 btn-outline justify-center py-3.5 text-base text-center inline-flex items-center"
            >
              🛒 {lang === 'en' ? 'Buy Now' : '立即订购'}
            </a>
          ) : (
            <a
              href={lang === 'en' ? '/en/contact' : '/contact'}
              class="flex-1 btn-outline justify-center py-3.5 text-base text-center inline-flex items-center"
            >
              📞 {lang === 'en' ? 'Contact Us' : '联系我们'}
            </a>
          )}
        </div>

        <!-- Download -->
        <a
          href="#"
          class="inline-flex items-center gap-2 text-sm text-brand-blue hover:underline"
          onclick="return false;"
        >
          📄 {t('product.datasheet')}
        </a>
      </div>
    </div>

    <!-- Specs table -->
    <div class="mt-12">
      <h2 class="text-xl font-bold text-gray-900 mb-6 pb-2 border-b-2 border-brand-blue inline-block">
        {t('product.specs')}
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-brand-blue text-white">
              <th class="text-left px-4 py-3 font-medium rounded-tl-lg w-1/3">
                {lang === 'en' ? 'Parameter' : '参数'}
              </th>
              <th class="text-left px-4 py-3 font-medium rounded-tr-lg">
                {lang === 'en' ? 'Value' : '规格值'}
              </th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(specs).map(([key, value], idx) => (
              <tr class={idx % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                <td class="px-4 py-3 text-gray-600 font-medium border-b border-gray-100">{key}</td>
                <td class="px-4 py-3 text-gray-900 border-b border-gray-100">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Related products -->
    <div class="mt-12">
      <h2 class="text-xl font-bold text-gray-900 mb-6">{t('product.related')}</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {product.relatedProducts.map(relId => (
          <a
            href={getLocalizedPath(`/products/pm-patch-cord/${relId}`, lang)}
            class="block p-4 bg-gray-50 rounded-xl hover:bg-brand-blue-light hover:border-brand-blue border border-transparent transition-all group"
          >
            <div class="text-3xl mb-2">🔵</div>
            <div class="text-xs font-mono text-gray-400 mb-1">
              {relId.toUpperCase().replace(/-/g, ' ')}
            </div>
            <div class="text-sm text-gray-700 group-hover:text-brand-blue font-medium line-clamp-2">
              {lang === 'en' ? 'Panda PM fiber patch cable' : '保偏跳线'}
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
