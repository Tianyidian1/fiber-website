---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl } from '../i18n/index';
const lang = getLangFromUrl(Astro.url);
---
<Layout title={lang === 'en' ? 'Page Not Found – FiberLink' : '页面未找到 – FiberLink'}>
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="text-8xl font-bold text-gray-200 mb-4">404</div>
      <h1 class="text-2xl font-bold text-gray-800 mb-2">
        {lang === 'en' ? 'Page Not Found' : '页面未找到'}
      </h1>
      <p class="text-gray-500 mb-8">
        {lang === 'en' ? 'The page you are looking for does not exist.' : '您访问的页面不存在。'}
      </p>
      <a href={lang === 'en' ? '/en' : '/'} class="btn-primary">
        {lang === 'en' ? 'Return to Home' : '返回首页'}
      </a>
    </div>
  </div>
</Layout>
